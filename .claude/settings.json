{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mise exec -- kubectl get*)",
      "Bash(mise exec -- kubectl describe*)",
      "Bash(mise exec -- kubectl logs*)",
      "Bash(mise exec -- flux get*)",
      "Bash(mise exec -- flux check*)",
      "Bash(mise exec -- flux diff*)",
      "Bash(mise exec -- flux build*)",
      "Bash(mise exec -- flux tree*)",
      "Bash(mise exec -- flux events*)",
      "Bash(mise exec -- flux stats*)",
      "Bash(mise exec -- talosctl get*)",
      "Bash(mise exec -- talosctl dmesg*)",
      "Bash(mise exec -- talosctl version*)",
      "Bash(mise exec -- kustomize build*)",
      "Bash(mise exec -- helm template*)",
      "Bash(./scripts/run-flux-local-test.sh*)",
      "Bash(./scripts/run-flux-local-diff.sh*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "mcp__grafana__query_prometheus",
      "mcp__grafana__query_loki_logs",
      "mcp__grafana__query_loki_stats",
      "mcp__grafana__query_loki_patterns",
      "mcp__grafana__list_prometheus_metric_names",
      "mcp__grafana__list_prometheus_metric_metadata",
      "mcp__grafana__list_prometheus_label_names",
      "mcp__grafana__list_prometheus_label_values",
      "mcp__grafana__list_loki_label_names",
      "mcp__grafana__list_loki_label_values",
      "mcp__grafana__list_datasources",
      "mcp__grafana__get_datasource",
      "mcp__grafana__search_dashboards",
      "mcp__grafana__get_dashboard_summary",
      "mcp__kubernetes__resources_list",
      "mcp__kubernetes__resources_get",
      "mcp__kubernetes__pods_list",
      "mcp__kubernetes__pods_list_in_namespace",
      "mcp__kubernetes__pods_get",
      "mcp__kubernetes__pods_log",
      "mcp__kubernetes__pods_top",
      "mcp__kubernetes__events_list",
      "mcp__kubernetes__namespaces_list",
      "mcp__kubernetes__nodes_log",
      "mcp__kubernetes__configuration_view"
    ],
    "deny": [
      "Edit(**/*.sops.yaml)",
      "Edit(**/*.sops.yml)",
      "Write(**/*.sops.yaml)",
      "Write(**/*.sops.yml)",
      "Read(./age.key)",
      "Read(**/*.key)",
      "Read(./kubeconfig)",
      "Read(./cloudflare-tunnel.json)",
      "Read(./github-push-token.txt)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_TRACES_EXPORTER": "otlp",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "1",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otlp.webgrip.dev:443",
    "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000",
    "OTEL_METRICS_INCLUDE_VERSION": "true",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_RESOURCE_ATTRIBUTES": "service.namespace=ai,deployment.environment=homelab"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-secrets.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-destructive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-manifest.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-skills.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-context.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/statusline.sh",
    "padding": 0
  },
  "extraKnownMarketplaces": {
    "webgrip": {
      "source": { "source": "github", "repo": "webgrip/claude-config" }
    },
    "webgrip-ai-skills": {
      "source": { "source": "git", "url": "https://forgejo.webgrip.dev/webgrip/webgrip-ai-skills.git" }
    }
  },
  "enabledPlugins": {
    "webgrip@webgrip": true,
    "skillsmith@webgrip-ai-skills": true
  }
}