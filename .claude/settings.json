{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mise exec -- kubectl get*)",
      "Bash(mise exec -- kubectl describe*)",
      "Bash(mise exec -- kubectl logs*)",
      "Bash(mise exec -- flux get*)",
      "Bash(mise exec -- flux check*)",
      "Bash(mise exec -- flux diff*)",
      "Bash(./scripts/run-flux-local-test.sh*)",
      "Bash(./scripts/run-flux-local-diff.sh*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Edit(**/*.sops.yaml)",
      "Edit(**/*.sops.yml)",
      "Write(**/*.sops.yaml)",
      "Write(**/*.sops.yml)",
      "Read(./age.key)",
      "Read(**/*.key)",
      "Read(./kubeconfig)",
      "Read(./cloudflare-tunnel.json)",
      "Read(./github-push-token.txt)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-secrets.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-destructive.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-manifest.sh" }
        ]
      }
    ]
  }
}
