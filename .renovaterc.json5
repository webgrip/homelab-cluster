{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  // Repo-local policy only. Shared org/GitOps extraction rules live in
  // webgrip/renovate-config; runtime/admin-only settings live in the
  // in-cluster Renovate ConfigMap.
  // Pinned to a semver release tag. webgrip/renovate-config uses semantic-release
  // with protected tags so these are immutable and auto-updatable by Renovate.
  extends: [
    "github>webgrip/renovate-config#v1.4.3",
    "github>webgrip/renovate-config:gitops#v1.4.3",
    "docker:enableMajor",
    ":automergeBranch",
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  // NOTE on Harbor-proxied charts: non-bootstrap OCI Helm charts have their
  // OCIRepository url pointed at Harbor's pull-through proxy (harbor.${SECRET_DOMAIN}/ghcr/…,
  // ADR-0023/0017). Renovate does its version lookup *through* Harbor — verified that
  // Harbor 2.15's proxy returns the full upstream tag list (not just cached tags), so
  // discovery is complete. registryAliases is NOT used: its keys match on registry host
  // only, so they can't disambiguate multiple upstreams behind one Harbor host+path.
  // Pinned @sha256: digests stay valid (proxy is content-addressable). The two packageRules
  // below that keyed on ghcr.io are widened to also match the harbor.…/ghcr proxy path.
  ignorePaths: [
    "**/*.sops.*",
    "age.key",
    "cloudflare-tunnel.json",
    "github-deploy.key",
    "github-deploy.key.pub",
    "github-push-token.txt",
    "kubeconfig",
    // The app is not referenced from observability/kustomization.yaml.
    "kubernetes/apps/observability/twitch-exporter/**",
    // Kyverno CLI tests intentionally use fake registries/images to exercise policy failures.
    "kubernetes/apps/kyverno/tests/**",
    // Kyverno policies use wildcard image patterns (*, !*, gcr.io/*) that Renovate misparses as Docker deps.
    "kubernetes/apps/kyverno/policies/**",
  ],
  postUpgradeTasks: {
    commands: [
      "./scripts/update-oci-digests.sh"
    ],
    fileFilters: [
      "kubernetes/apps/**/ocirepository.yaml"
    ],
    executionMode: "branch",
  },
  prBodyNotes: [
    "{{#if isMajor}}⚠️ Major update: review upstream migration notes, chart values, and rollout impact before merging.{{/if}}",
    "{{#if isVulnerabilityAlert}}Security update: prioritize review and verify the vulnerable component is actually deployed.{{/if}}",
    "{{#if isGroup}}Grouped GitOps PR: confirm the group is operationally coherent before enabling automerge.{{/if}}",
    "Merge Confidence badges are included where Renovate supports them; low/neutral confidence means this update deserves a manual impact check before merge.",
  ],
  packageRules: [
    {
      // Digest-only updates change WHICH bytes a tag resolves to, not the version;
      // upstream tag re-pushes (e.g. coredns chart 1.46.0, three digests so far)
      // otherwise wedge verify-oci-digests CI until a human approves the fix.
      description: "Digest-only updates skip dashboard approval and automerge once checks pass",
      matchUpdateTypes: [
        "digest"
      ],
      dependencyDashboardApproval: false,
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "0 days",
      schedule: [
        "at any time"
      ],
    },
    {
      description: "Prioritize vulnerability fixes ahead of all routine dependency updates",
      matchJsonata: [
        "$exists(vulnerabilityFixVersion)"
      ],
      dependencyDashboardApproval: false,
      schedule: [
        "at any time"
      ],
      prPriority: 20,
    },
    {
      description: "Automerge patch-level vulnerability fixes after checks pass",
      matchJsonata: [
        "$exists(vulnerabilityFixVersion) and updateType = 'patch'"
      ],
      automerge: true,
      automergeType: "branch",
      dependencyDashboardApproval: false,
      minimumReleaseAge: "0 days",
      schedule: [
        "at any time"
      ],
      prPriority: 20,
    },
    {
      description: "Prioritize updates for cluster-critical platform paths ahead of normal app updates",
      matchFileNames: [
        "bootstrap/**",
        "talos/**",
        "kubernetes/apps/cert-manager/**",
        "kubernetes/apps/cnpg-dr/**",
        "kubernetes/apps/cnpg-system/**",
        "kubernetes/apps/flux-system/**",
        "kubernetes/apps/kube-system/**",
        "kubernetes/apps/longhorn-system/**",
        "kubernetes/apps/network/**",
        "kubernetes/apps/renovate/**",
      ],
      prPriority: 10,
    },
    {
      description: "Group Flux controller updates and keep Renovate's Flux manager away from digest-pinned OCIRepository files. OCIRepository tags are updated by custom.regex and scripts/update-oci-digests.sh refreshes spec.ref.digest from the registry manifest digest.",
      matchManagers: [
        "flux"
      ],
      groupName: "Flux controllers",
      pinDigests: false,
      separateMinorPatch: true,
      separateMultipleMajor: true,
      commitBodyTable: true,
    },
    {
      description: "Automerge Flux OCI Helm chart patch updates; digest pins are refreshed by post-upgrade tasks",
      matchManagers: [
        "custom.regex"
      ],
      matchFileNames: [
        "kubernetes/apps/**/ocirepository.yaml"
      ],
      matchUpdateTypes: [
        "patch"
      ],
      automerge: true,
      automergeType: "pr",
      schedule: [
        "at any time"
      ],
    },
    {
      description: "Disable digest pinning for talos/ version files — talhelper uses plain semver strings; appending @sha256: makes talenv.yaml unparseable",
      matchFileNames: [
        "talos/**"
      ],
      pinDigests: false,
    },
    {
      description: "Flux Operator Group",
      groupName: "flux-operator",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "/flux-operator/",
        "/flux-instance/",
        "/flux-operator-manifests/"
      ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      commitBodyTable: true,
      minimumGroupSize: 1,
    },
    {
      description: "Use fully qualified Postgres Alpine tags",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "postgres",
        "docker.io/library/postgres"
      ],
      allowedVersions: "/^\\d+\\.\\d+-alpine\\d+\\.\\d+$/",
    },
    {
      description: "Helm charts that use a dedicated sha: field for digest pinning (e.g. kube-prometheus-stack). Renovate updates the sha: field directly via customManagers; do not also embed digest inline in tag: which causes a double-digest InvalidImageName error.",
      matchManagers: [
        "helm-values"
      ],
      matchPackageNames: [
        "quay.io/prometheus-operator/prometheus-operator",
        "quay.io/prometheus-operator/prometheus-config-reloader",
        "quay.io/prometheus/prometheus",
        "quay.io/prometheus/alertmanager"
      ],
      matchUpdateTypes: [
        "pinDigest",
        "digest"
      ],
      enabled: false,
    },
    {
      description: "Group GitHub Actions updates separately from GitOps/runtime dependency updates",
      matchManagers: [
        "github-actions"
      ],
      groupName: "GitHub Actions",
      automerge: false,
      commitBodyTable: true,
    },
    {
      description: "Auto-merge GitHub Actions patch/digest updates only after checks pass",
      matchManagers: [
        "github-actions"
      ],
      pinDigests: true,
      automerge: true,
      automergeType: "branch",
      minimumReleaseAge: "1 day",
      matchUpdateTypes: [
        "patch",
        "digest"
      ],
    },
    {
      description: "Group Mise tool updates separately from GitOps/runtime dependency updates",
      matchManagers: [
        "mise"
      ],
      groupName: "Mise tools",
      commitBodyTable: true,
    },
    {
      description: "Auto-merge Mise tool patch updates only after checks pass",
      matchManagers: [
        "mise"
      ],
      automerge: true,
      automergeType: "branch",
      minimumReleaseAge: "1 day",
      matchUpdateTypes: [
        "patch"
      ],
    },
    {
      description: "Hold Python at the last installable mise pin; python@3.14.4 and python@3.14.5 currently fail mise install because the upstream standalone artifact is missing a lib directory.",
      matchManagers: [
        "mise"
      ],
      matchDepNames: [
        "python"
      ],
      matchPackageNames: [
        "python/cpython"
      ],
      allowedVersions: "<=3.14.2",
    },
    {
      description: "Group application container image references outside the Kubernetes GitOps tree",
      matchManagers: [
        "dockerfile",
        "docker-compose"
      ],
      matchDatasources: [
        "docker"
      ],
      groupName: "application container images",
      pinDigests: true,
      commitBodyTable: true,
    },
    {
      description: "Gate minor updates for cluster-critical platform files",
      matchFileNames: [
        "bootstrap/**",
        "kubernetes/apps/cert-manager/**",
        "kubernetes/apps/cnpg-dr/**",
        "kubernetes/apps/cnpg-system/**",
        "kubernetes/apps/flux-system/**",
        "kubernetes/apps/kube-system/**",
        "kubernetes/apps/longhorn-system/**",
        "kubernetes/apps/network/**",
        "kubernetes/apps/renovate/**",
      ],
      matchUpdateTypes: [
        "minor"
      ],
      dependencyDashboardApproval: true,
      minimumReleaseAge: "7 days",
    },
    {
      description: "Keep vchord-scratch CNPG extension images on their PostgreSQL 18 compatibility stream",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "ghcr.io/tensorchord/vchord-scratch"
      ],
      matchCurrentValue: "/^pg18-v/",
      allowedVersions: "/^pg18-v\\d+\\.\\d+\\.\\d+$/",
      separateMultipleMajor: true,
    },
    {
      description: "Treat missing release timestamps as stable for GHCR Docker datasource updates; Renovate only supports Docker release timestamps on Docker Hub, so GHCR OCI artifacts can otherwise stay pending forever. Also covers charts proxied through Harbor (harbor.${SECRET_DOMAIN}/<project>/…), whose timestamps are likewise unavailable.",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "/^ghcr\\.io\\//",
        "/^harbor\\.webgrip\\.dev\\//"
      ],
      minimumReleaseAgeBehaviour: "timestamp-optional",
    },
    {
      description: "Ungroup Kubernetes app container images; overrides the global 'GitOps container images' group so each dependency uses Renovate's normal per-dependency branch/topic. The shared app-template and shared busybox rules below still win for those packages because they come last.",
      matchFileNames: [
        "kubernetes/apps/**",
        "!kubernetes/apps/**/ocirepository.yaml"
      ],
      matchDatasources: [
        "docker"
      ],
      groupName: null,
    },
    {
      description: "Group shared app-template updates into a dedicated PR (matches both the upstream ref and the Harbor pull-through proxy path).",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "ghcr.io/bjw-s-labs/helm/app-template",
        "harbor.webgrip.dev/ghcr/bjw-s-labs/helm/app-template"
      ],
      groupName: "shared app-template",
      additionalBranchPrefix: "shared-app-template-",
      commitBodyTable: true,
    },
    {
      description: "Group shared busybox updates into a dedicated PR",
      matchDatasources: [
        "docker"
      ],
      matchPackageNames: [
        "docker.io/library/busybox"
      ],
      groupName: "shared busybox",
      additionalBranchPrefix: "shared-busybox-",
      commitBodyTable: true,
    },
    {
      description: "Group Grafana.com dashboard revision updates into one reviewable PR",
      matchDatasources: [
        "custom.grafana-dashboards"
      ],
      groupName: "Grafana dashboards",
      additionalBranchPrefix: "grafana-dashboards-",
      commitBodyTable: true,
      addLabels: [
        "renovate/grafana-dashboard"
      ],
    },
    {
      matchDatasources: [
        "docker"
      ],
      semanticCommitScope: "container",
      commitMessageTopic: "image {{depName}}",
      addLabels: [
        "renovate/container"
      ],
    },
    {
      matchDatasources: [
        "helm"
      ],
      semanticCommitScope: "helm",
      commitMessageTopic: "chart {{depName}}",
      addLabels: [
        "renovate/helm"
      ],
    },
    {
      matchManagers: [
        "github-actions"
      ],
      semanticCommitType: "ci",
      semanticCommitScope: "github-action",
      commitMessageTopic: "action {{depName}}",
      addLabels: [
        "renovate/github-action"
      ],
    },
    {
      matchDatasources: [
        "github-releases"
      ],
      semanticCommitScope: "github-release",
      commitMessageTopic: "release {{depName}}",
      addLabels: [
        "renovate/github-release"
      ],
    },
    {
      matchManagers: [
        "mise"
      ],
      semanticCommitScope: "mise",
      commitMessageTopic: "tool {{depName}}",
    },
  ],
}