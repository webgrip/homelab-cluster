<!-- Stub injected into every page <head> (ConfigMap forgejo-custom-header,
     subPath mount — changing THIS file still restarts Forgejo, so keep it
     stable). The actual UI lives in /assets/wg/* (ConfigMap
     forgejo-custom-assets, directory mount): those files hot-update without a
     pod restart (kubelet sync ~1min; browsers refresh within
     STATIC_CACHE_TIME=5m). Canary channel: run
     localStorage.setItem('wg-ui-canary','1') in the browser console to load
     wg-pipeline-canary.js instead; remove the key to go back to stable.
     Go template: never write two adjacent open braces in this file. -->
<link rel="stylesheet" href="/assets/wg/wg-custom.css">
<script>
(function () {
  var suffix = '';
  try { suffix = localStorage.getItem('wg-ui-canary') === '1' ? '-canary' : ''; } catch (e) { }
  var s = document.createElement('script');
  s.defer = true;
  s.src = '/assets/wg/wg-pipeline' + suffix + '.js';
  document.head.appendChild(s);
})();
</script>
