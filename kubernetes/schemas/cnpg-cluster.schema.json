{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "postgresql.cnpg.io/v1"
    },
    "kind": {
      "const": "Cluster"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}